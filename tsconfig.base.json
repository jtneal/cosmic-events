{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@cosmic-events/common-data-access": ["libs/common/data-access/src/index.ts"],
      "@cosmic-events/common-feature": ["libs/common/feature/src/index.ts"],
      "@cosmic-events/common-ui": ["libs/common/ui/src/index.ts"],
      "@cosmic-events/common-util": ["libs/common/util/src/index.ts"],
      "@cosmic-events/home-ui": ["libs/home/ui/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
